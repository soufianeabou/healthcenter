# Backend Gateway URL for OAuth authentication
# In production, the browser talks to https://hc.aui.ma
# and nginx proxies /auth, /oauth2, /logout to the Spring gateway on 192.168.1.97:8222.
# So in production you can either:
#   - Omit this variable (default is https://hc.aui.ma), or
#   - Set it explicitly to https://hc.aui.ma
#
# For local dev, you typically point directly to the gateway:
#   VITE_AUTH_BASE_URL=https://192.168.1.97:8222
#
# Default (safe for prod behind nginx):
VITE_AUTH_BASE_URL=https://hc.aui.ma
